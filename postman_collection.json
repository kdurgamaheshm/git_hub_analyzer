		"name": "GitHub Profile Analyzer API",
		"description": "Postman Collection for testing the GitHub Profile Analyzer REST API endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Analyze & Store Profile",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/analyze/:username",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"analyze",
						":username"
					],
					"variable": [
						{
							"key": "username",
							"value": "octocat",
							"description": "GitHub username to fetch and analyze"
						}
					]
				},
				"description": "Queries the GitHub Public API for profile data and repositories, calculates insights (like total stars, language distributions, primary language, and most-starred repository), and inserts or updates the record in MySQL."
			},
			"response": []
		},
		{
			"name": "Fetch Stored Profiles List",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/profiles",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"profiles"
					]
				},
				"description": "Retrieves the list of all analyzed profiles persisted in the database, ordered by the most recently analyzed."
			},
			"response": []
		},
		{
			"name": "Fetch Single Profile Data",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/profiles/:username",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"profiles",
						":username"
					],
					"variable": [
						{
							"key": "username",
							"value": "octocat",
							"description": "GitHub username of the stored record"
						}
					]
				},
				"description": "Fetches the full details of a single user profile from the database."
			},
			"response": []
		},
		{
			"name": "Delete Profile Analysis",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/profiles/:username",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"profiles",
						":username"
					],
					"variable": [
						{
							"key": "username",
							"value": "octocat",
							"description": "GitHub username to delete"
						}
					]
				},
				"description": "Deletes the stored analysis record from the local MySQL database."
			},
			"response": []
		}
